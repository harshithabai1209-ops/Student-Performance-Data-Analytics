import sqlite3

def create_db():
    conn = sqlite3.connect("student.db")
    cursor = conn.cursor()

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS register(
        name TEXT,
        mobile TEXT,
        email TEXT PRIMARY KEY,
        pwd TEXT
    )
    """)

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS student(
        rno TEXT PRIMARY KEY,
        name TEXT,
        t1 INTEGER,
        t2 INTEGER,
        t3 INTEGER,
        avg REAL
    )
    """)

    conn.commit()
    conn.close()
