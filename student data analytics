# ---------------- ANALYSE PERFORMANCE ----------------
def analyse():
    conn = sqlite3.connect("student.db")
    cursor = conn.cursor()
    cursor.execute("SELECT rno, t1, t2, t3 FROM student")
    data = cursor.fetchall()
    conn.close()

    if not data:
        messagebox.showerror("Error", "No Student Data Available")
        return

    rnos = []
    t1_marks = []
    t2_marks = []
    t3_marks = []

    for row in data:
        rnos.append(row[0])
        t1_marks.append(row[1])
        t2_marks.append(row[2])
        t3_marks.append(row[3])

    # BAR GRAPH
    plt.figure()
    plt.bar(rnos, t1_marks)
    plt.title("T1 Performance")
    plt.show()

    # LINE GRAPH
    plt.figure()
    plt.plot(rnos, t1_marks, marker='o', label="T1")
    plt.plot(rnos, t2_marks, marker='o', label="T2")
    plt.plot(rnos, t3_marks, marker='o', label="T3")
    plt.legend()
    plt.title("Test Wise Performance")
    plt.show()

