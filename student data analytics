from tkinter import *
from tkinter import messagebox
from database import create_db
import sqlite3
import matplotlib.pyplot as plt

create_db()

# ---------------- REGISTER STAFF ----------------
def register_staff():
    win = Toplevel(root)
    win.title("Register Staff")
    win.geometry("400x400")

    Label(win, text="Name").pack()
    name = Entry(win)
    name.pack()

    Label(win, text="Mobile").pack()
    mobile = Entry(win)
    mobile.pack()

    Label(win, text="Email").pack()
    email = Entry(win)
    email.pack()

    Label(win, text="Password").pack()
    pwd = Entry(win, show="*")
    pwd.pack()

    def save():
        if not name.get() or not mobile.get() or not email.get() or not pwd.get():
            messagebox.showerror("Error", "All Fields Required")
            return

        if len(mobile.get()) != 10 or not mobile.get().isdigit():
            messagebox.showerror("Error", "Invalid Mobile Number")
            return

        conn = sqlite3.connect("student.db")
        cursor = conn.cursor()

        try:
            cursor.execute("INSERT INTO register VALUES (?,?,?,?)",
                           (name.get(), mobile.get(), email.get(), pwd.get()))
            conn.commit()
            messagebox.showinfo("Success", "Registered Successfully")
            win.destroy()
        except sqlite3.IntegrityError:
            messagebox.showerror("Error", "Email Already Exists")

        conn.close()

    Button(win, text="Register", command=save).pack(pady=20)

# ---------------- ADD STUDENT ----------------
def add_student():
    win = Toplevel(root)
    win.title("Add Student")
    win.geometry("400x400")

    Label(win, text="Roll No").pack()
    rno = Entry(win)
    rno.pack()

    Label(win, text="Name").pack()
    name = Entry(win)
    name.pack()

    Label(win, text="T1 Marks").pack()
    t1 = Entry(win)
    t1.pack()

    Label(win, text="T2 Marks").pack()
    t2 = Entry(win)
    t2.pack()

    Label(win, text="T3 Marks").pack()
    t3 = Entry(win)
    t3.pack()

    def save():
        if not rno.get() or not name.get() or not t1.get() or not t2.get() or not t3.get():
            messagebox.showerror("Error", "All Fields Required")
            return

        if not t1.get().isdigit() or not t2.get().isdigit() or not t3.get().isdigit():
            messagebox.showerror("Error", "Marks must be numbers")
            return

        try:
            avg = (int(t1.get()) + int(t2.get()) + int(t3.get())) / 3

            conn = sqlite3.connect("student.db")
            cursor = conn.cursor()

            cursor.execute("INSERT INTO student VALUES (?,?,?,?,?,?)",
                           (rno.get(), name.get(),
                            int(t1.get()), int(t2.get()), int(t3.get()), avg))
            conn.commit()
            conn.close()

            messagebox.showinfo("Success", "Student Added Successfully")
            win.destroy()

        except sqlite3.IntegrityError:
            messagebox.showerror("Error", "Roll Number Already Exists")

    Button(win, text="Save", command=save).pack(pady=20)

# ---------------- VIEW STUDENTS ----------------
def view_students():
    win = Toplevel(root)
    win.title("View Students")
    win.geometry("650x400")

    conn = sqlite3.connect("student.db")
    cursor = conn.cursor()
